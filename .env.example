ASPNETCORE_ENVIRONMENT=Development
API_PORT=8080

POSTGRES_DB=cmssync
POSTGRES_USER=cmsuser
POSTGRES_PASSWORD=cmspassword
POSTGRES_PORT=5432

DEFAULT_CONNECTION=Host=db;Port=5432;Database=cmssync;Username=cmsuser;Password=cmspassword

REDIS_CONNECTION=redis:6379

RABBITMQ_ENABLED=true
RABBITMQ_HOSTNAME=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_QUEUE_NAME=cms-events
RABBITMQ_RETRY_QUEUE_NAME=cms-events.retry
RABBITMQ_DEAD_LETTER_QUEUE_NAME=cms-events.dead-letter
RABBITMQ_RETRY_DELAY_MILLISECONDS=5000
RABBITMQ_MAX_RETRY_ATTEMPTS=3
